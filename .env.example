### Core auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

### Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

### Cookie domain (optional)
# COOKIE_DOMAIN=.example.com

### Email/SMTP (required for invite + reset password flows)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

### Departures API
REJSEPLANEN_API_KEY=change-me
REJSEPLANEN_STOP_ID_1=3849
REJSEPLANEN_STOP_ID_2=2859

### Legacy fallback stop id (optional, kept for compatibility)
# REJSEPLANEN_STOP_ID=3849
